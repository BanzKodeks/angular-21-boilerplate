{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "./src",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist/out-tsc",
    "strict": false,
    "noImplicitReturns": false,
    "noPropertyAccessFromIndexSignature": false,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@app/*": [
        "src/app/*"
      ],
      "@environments/*": [
        "src/environments/*"
      ]
    }
  },
  "angularCompilerOptions": {
    "strictTemplates": false
  }
}